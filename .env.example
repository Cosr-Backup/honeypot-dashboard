# ── 蜜罐仪表盘环境变量配置 ─────────────────────────────────────
# 复制此文件为 .env 并填写实际值：cp .env.example .env
# 真实 .env 不应提交到版本控制。

# ── 界面语言 ──────────────────────────────────────────────────
# zh = 中文（默认），en = English
LANG=zh

# ── 数据路径 ──────────────────────────────────────────────────
HONEYPOT_DATA_DIR=/data
COWRIE_LOG_PATH=/cowrie-logs/cowrie.json

# ── 服务配置 ──────────────────────────────────────────────────
SERVE_HOST=127.0.0.1
SERVE_PORT=9999
REGEN_INTERVAL=300
TZ=America/New_York

# ── LLM 配置 ─────────────────────────────────────────────────
# LLM_PROVIDER: ollama（默认）| openai | none（禁用 LLM）
LLM_PROVIDER=ollama

# Ollama 配置（LLM_PROVIDER=ollama 时生效）
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# OpenAI 兼容 API 配置（LLM_PROVIDER=openai 时生效）
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
